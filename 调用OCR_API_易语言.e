.子程序 OCR识别_Base64
    .局部变量 服务器地址, 文本型
    .局部变量 图片路径, 文本型
    .局部变量 图片数据, 字节集
    .局部变量 图片Base64, 文本型
    .局部变量 请求体, 文本型
    .局部变量 返回文本, 文本型
    .局部变量 json, 类_json
    .局部变量 i, 整数型
    .局部变量 总数, 整数型
    .局部变量 文字, 文本型
    .局部变量 置信度, 文本型
    .局部变量 x, 文本型
    .局部变量 y, 文本型

    服务器地址 ＝ “http://127.0.0.1:8000/ocr/base64”
    图片路径 ＝ “C:\截图.png”     ' ← 改成你自己的图片路径

    ' ---- 1. 读取图片并转 Base64 ----
    图片数据 ＝ 读入文件 (图片路径)
    如果真 (取字节集长度 (图片数据) ＝ 0)
        调试输出 (“[!!] 图片读取失败，请检查路径: ” ＋ 图片路径)
        返回
    如果真结束
    图片Base64 ＝ 编码_BASE64编码 (图片数据)
    调试输出 (“[✓] 图片已读取，大小: ” ＋ 到文本 (取字节集长度 (图片数据) ÷ 1024) ＋ “ KB”)

    ' ---- 2. 构造 JSON 请求体 ----
    请求体 ＝ “{”
    请求体 ＝ 请求体 ＋ #引号 ＋ “image” ＋ #引号 ＋ “: ” ＋ #引号 ＋ 图片Base64 ＋ #引号
    请求体 ＝ 请求体 ＋ “}”

    ' ---- 3. POST 请求 ----
    调试输出 (“[→] 正在发送请求...”)
    返回文本 ＝ 网页_访问S (服务器地址, 1, 请求体, , , “Content-Type: application/json”, , , , , , , , , , , , )
    调试输出 (“[✓] 请求完成”)

    ' ---- 4. 解析 JSON 返回 ----
    json.解析 (返回文本)
    如果真 (json.取通用属性 (“code”) ≠ “0”)
        调试输出 (“[!!] 识别失败: ” ＋ json.取通用属性 (“message”))
        返回
    如果真结束

    ' ---- 5. 遍历结果 ----
    json.取属性 (“data”).取成员数 ()
    总数 ＝ json.成员数 (“data”)
    调试输出 (“[✓] 共识别到 ” ＋ 到文本 (总数) ＋ “ 个文字”)
    调试输出 (“”)

    .变量循环首 (0, 总数 － 1, 1, i)
        文字 ＝ json.取通用属性 (“data[” ＋ 到文本 (i) ＋ “].text”)
        置信度 ＝ json.取通用属性 (“data[” ＋ 到文本 (i) ＋ “].confidence”)
        x ＝ json.取通用属性 (“data[” ＋ 到文本 (i) ＋ “].x”)
        y ＝ json.取通用属性 (“data[” ＋ 到文本 (i) ＋ “].y”)
        调试输出 (“  [” ＋ 到文本 (i ＋ 1) ＋ “] 文字: ” ＋ 文字)
        调试输出 (“      置信度: ” ＋ 置信度)
        调试输出 (“      坐标: (” ＋ x ＋ “, ” ＋ y ＋ “)”)
        调试输出 (“”)
    .变量循环尾 ()


.子程序 OCR查找_Base64
    .局部变量 服务器地址, 文本型
    .局部变量 图片路径, 文本型
    .局部变量 图片数据, 字节集
    .局部变量 图片Base64, 文本型
    .局部变量 请求体, 文本型
    .局部变量 返回文本, 文本型
    .局部变量 json, 类_json
    .局部变量 i, 整数型
    .局部变量 总数, 整数型
    .局部变量 文字, 文本型
    .局部变量 置信度, 文本型
    .局部变量 x, 文本型
    .局部变量 y, 文本型
    .局部变量 匹配方式, 文本型

    服务器地址 ＝ “http://127.0.0.1:8000/ocr/search/base64”
    图片路径 ＝ “C:\截图.png”     ' ← 改成你自己的图片路径

    ' ---- 1. 读取图片 ----
    图片数据 ＝ 读入文件 (图片路径)
    如果真 (取字节集长度 (图片数据) ＝ 0)
        调试输出 (“[!!] 图片读取失败”)
        返回
    如果真结束
    图片Base64 ＝ 编码_BASE64编码 (图片数据)

    ' ---- 2. 构造 JSON ----
    请求体 ＝ “{”
    请求体 ＝ 请求体 ＋ #引号 ＋ “image” ＋ #引号 ＋ “: ” ＋ #引号 ＋ 图片Base64 ＋ #引号 ＋ “, ”
    请求体 ＝ 请求体 ＋ #引号 ＋ “keyword” ＋ #引号 ＋ “: ” ＋ #引号 ＋ “要查找的文字” ＋ #引号 ＋ “, ”
    请求体 ＝ 请求体 ＋ #引号 ＋ “fuzzy” ＋ #引号 ＋ “: true”
    请求体 ＝ 请求体 ＋ “}”

    ' ---- 3. POST ----
    调试输出 (“[→] 正在查找文字...”)
    返回文本 ＝ 网页_访问S (服务器地址, 1, 请求体, , , “Content-Type: application/json”, , , , , , , , , , , , )
    调试输出 (“[✓] 请求完成”)

    ' ---- 4. 解析 ----
    json.解析 (返回文本)
    如果真 (json.取通用属性 (“code”) ≠ “0”)
        调试输出 (“[!!] 查找失败: ” ＋ json.取通用属性 (“message”))
        返回
    如果真结束

    调试输出 (“[✓] 关键字: ” ＋ json.取通用属性 (“keyword”))
    调试输出 (“[✓] 图片中共识别到: ” ＋ json.取通用属性 (“total_recognized”) ＋ “ 个文字”)

    json.取属性 (“matches”).取成员数 ()
    总数 ＝ json.成员数 (“matches”)

    .如果 (总数 ＞ 0)
        调试输出 (“[✓] 匹配到 ” ＋ 到文本 (总数) ＋ “ 个结果:”)
        调试输出 (“”)
        .变量循环首 (0, 总数 － 1, 1, i)
            文字 ＝ json.取通用属性 (“matches[” ＋ 到文本 (i) ＋ “].text”)
            置信度 ＝ json.取通用属性 (“matches[” ＋ 到文本 (i) ＋ “].confidence”)
            x ＝ json.取通用属性 (“matches[” ＋ 到文本 (i) ＋ “].x”)
            y ＝ json.取通用属性 (“matches[” ＋ 到文本 (i) ＋ “].y”)
            匹配方式 ＝ json.取通用属性 (“matches[” ＋ 到文本 (i) ＋ “].match_type”)
            调试输出 (“  [” ＋ 到文本 (i ＋ 1) ＋ “] → ” ＋ 文字)
            调试输出 (“      置信度: ” ＋ 置信度 ＋ “ | 坐标: (” ＋ x ＋ “, ” ＋ y ＋ “)” ＋ “ | 匹配: ” ＋ 匹配方式)
            调试输出 (“”)
        .变量循环尾 ()
    .否则
        调试输出 (“[!] 未找到匹配的文字”)
    .如果结束
